	partition Dim_Calendario = calculated
		mode: import
		source =
				
				VAR _MinDate = DATE(1950, 1, 1)
				VAR _MaxDate = DATE(2025, 12, 31)
				RETURN
				ADDCOLUMNS(
				    CALENDAR(_MinDate, _MaxDate),
				    "DataKey", FORMAT([Date], "YYYYMMDD"),
				    "Ano", YEAR([Date]),
				    "Mês", MONTH([Date]),
				    "NomeMês", FORMAT([Date], "MMMM"),
				    "NomeMêsAbrev", FORMAT([Date], "MMM"),
				    "Trimestre", "T" & QUARTER([Date]),
				    "Dia", DAY([Date]),
				    "DiaSemana", FORMAT([Date], "dddd"),
				    "AnoMes", FORMAT([Date], "YYYY-MM")
				)

	annotation PBI_Id = f0b3215ea43246149534b0a794de5f15

